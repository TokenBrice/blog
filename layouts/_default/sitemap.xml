{{- $sitePages := where .Site.RegularPages "Params.hidden" "!=" true -}}
{{- $pages := slice .Site.Home }}
{{- $pages = $pages | append $sitePages -}}

{{- $output := slice }}
{{- $output = $output | append "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?>" -}}
{{- $output = $output | append "<urlset xmlns=\"http://www.sitemaps.org/schemas/sitemap/0.9\">" -}}
{{- range where $pages "RelPermalink" "!=" "" }}
    {{- if and
        (ne .Type "search")
        (ne .Kind "term")
        (ne .Kind "taxonomy")
        (not (eq .RelPermalink "/search"))
        (not (hasSuffix .RelPermalink "/search/"))
        (not (strings.Contains .RelPermalink "/page/")) }}
    {{- $output = $output | append "    <url>" -}}
    {{- $output = $output | append (printf "      <loc>%s</loc>" .Permalink) -}}
    {{- if not .Lastmod.IsZero }}
    {{- $output = $output | append (printf "      <lastmod>%s</lastmod>" (.Lastmod.Format "2006-01-02T15:04:05-07:00")) -}}
    {{- end }}
    {{- $output = $output | append "      <changefreq>monthly</changefreq>" -}}
    {{- $output = $output | append "      <priority>0.5</priority>" -}}
    {{- $output = $output | append "    </url>" -}}
    {{- end }}
{{- end }}
{{- $output = $output | append "</urlset>" -}}

{{- delimit $output "\n" | safeHTML }}
