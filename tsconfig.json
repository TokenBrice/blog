{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "lib": ["ES2022", "DOM"],
    "baseUrl": ".",
    "paths": { "*": ["assets/ts/*", "themes/hugo-theme-stack/assets/ts/*"] }
  },
  "include": ["assets/ts/**/*", "themes/hugo-theme-stack/assets/ts/**/*"]
}
