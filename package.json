{
  "name": "tokenbrice-blog",
  "version": "1.0.0",
  "description": "TokenBrice Blog - Brutally Honest DeFi",
  "private": true,
  "type": "module",
  "scripts": {
    "serve": "hugo server --disableFastRender --navigateToChanged",
    "build": "hugo --gc --minify --cleanDestinationDir",
    "typecheck": "tsc --noEmit",
    "validate:frontmatter": "python3 scripts/validate-frontmatter.py",
    "validate:content": "python3 scripts/validate-content-safety.py",
    "validate:site": "python3 scripts/validate-site-output.py",
    "verify": "npm run validate:frontmatter && npm run validate:content && npm run typecheck && npm run build && npm run validate:site"
  },
  "author": "TokenBrice",
  "license": "CC-BY-NC-SA-4.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TokenBrice/blog.git"
  },
  "bugs": {
    "url": "https://github.com/TokenBrice/blog/issues"
  },
  "homepage": "https://github.com/TokenBrice/blog#readme",
  "devDependencies": {
    "lighthouse": "^13.1.0",
    "typescript": "^5.6.0"
  }
}
